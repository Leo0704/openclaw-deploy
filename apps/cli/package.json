{
  "name": "lobster-assistant",
  "version": "1.0.16",
  "description": "龙虾助手 - OpenClaw 一键部署工具",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist bin",
    "pkg": "pkg . --targets node18-macos-arm64,node18-macos-x64,node18-linux-x64,node18-win-x64 --output-path bin"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "outputPath": "bin"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@yao-pkg/pkg": "^5.16.1",
    "typescript": "^5.7.2"
  }
}
