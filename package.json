{
  "name": "lobster-assistant",
  "version": "1.0.55",
  "private": true,
  "description": "龙虾助手 - OpenClaw 一键部署工具",
  "scripts": {
    "build": "cd apps/cli && npm run build",
    "start": "cd apps/cli && node dist/index.js",
    "pkg": "cd apps/cli && npm run pkg",
    "clean": "cd apps/cli && npm run clean",
    "validate:release-version": "node scripts/validate-release-version.js",
    "test": "cd tests && npm test",
    "test:watch": "cd tests && npm run test:watch"
  },
  "keywords": [
    "openclaw",
    "ai",
    "claude",
    "deployment"
  ],
  "author": "Lobster Assistant Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.12.0"
  }
}
